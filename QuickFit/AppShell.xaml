<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="QuickFit.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:QuickFit"
    Shell.FlyoutBehavior="Disabled">

    <TabBar x:Name="MyTabBar">
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage"/>
        </Tab>
        <Tab Title="Exercise" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:ExercisePage}" Route="ExercisePage"/>
        </Tab>
        <Tab Title="Nutrition" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:NutritionPage}" Route="NutritionPage"/>
        </Tab>
    </TabBar>

</Shell>